{
  "name": "Writing Publishing",
  "version": "1.0.0",
  "category": "writing",
  "kernelId": "writing",
  "dockerImage": "colossus/mk-writing:latest",
  "resources": {
    "cpu": "250m",
    "memory": "512Mi",
    "minReplicas": 2,
    "maxReplicas": 10
  },
  "graphqlSchema": "schema.graphql",
  "eventSubscriptions": [
    "user.follow",
    "content.like"
  ],
  "oauthScopesNeeded": [],
  "storageBackends": [
    "s3",
    "ipfs"
  ],
  "uiModule": {
    "webComponent": "writing-widget",
    "mobileComponent": "WritingScreen",
    "defaultRoute": "/writing"
  },
  "monetization": {
    "allowedMethods": [
      "paid_newsletter",
      "tipping"
    ]
  }
}