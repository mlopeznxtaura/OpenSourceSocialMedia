{
  "name": "Personal Social Graph",
  "version": "1.0.0",
  "category": "social",
  "kernelId": "personal-social",
  "dockerImage": "colossus/mk-personal-social:latest",
  "resources": {
    "cpu": "250m",
    "memory": "512Mi",
    "minReplicas": 2,
    "maxReplicas": 10
  },
  "graphqlSchema": "schema.graphql",
  "eventSubscriptions": [
    "user.follow",
    "content.like",
    "content.comment"
  ],
  "oauthScopesNeeded": [],
  "storageBackends": [
    "s3",
    "ipfs"
  ],
  "uiModule": {
    "webComponent": "personal-social-widget",
    "mobileComponent": "PersonalSocialScreen",
    "defaultRoute": "/personal-social"
  },
  "monetization": {
    "allowedMethods": [
      "none"
    ]
  }
}