{
  "name": "Video Distribution",
  "version": "1.0.0",
  "category": "video",
  "kernelId": "video",
  "dockerImage": "colossus/mk-video:latest",
  "resources": {
    "cpu": "250m",
    "memory": "512Mi",
    "minReplicas": 2,
    "maxReplicas": 10
  },
  "graphqlSchema": "schema.graphql",
  "eventSubscriptions": [
    "user.follow",
    "content.like"
  ],
  "oauthScopesNeeded": [],
  "storageBackends": [
    "s3",
    "ipfs"
  ],
  "uiModule": {
    "webComponent": "video-widget",
    "mobileComponent": "VideoScreen",
    "defaultRoute": "/video"
  },
  "monetization": {
    "allowedMethods": [
      "ad_revenue",
      "channel_memberships"
    ]
  }
}