{
  "name": "CAD Collaboration",
  "version": "1.0.0",
  "category": "cad",
  "kernelId": "cad-collaboration",
  "dockerImage": "colossus/mk-cad-collaboration:latest",
  "resources": {
    "cpu": "250m",
    "memory": "512Mi",
    "minReplicas": 2,
    "maxReplicas": 10
  },
  "graphqlSchema": "schema.graphql",
  "eventSubscriptions": [
    "user.follow"
  ],
  "oauthScopesNeeded": [],
  "storageBackends": [
    "s3",
    "ipfs"
  ],
  "uiModule": {
    "webComponent": "cad-collaboration-widget",
    "mobileComponent": "CadCollaborationScreen",
    "defaultRoute": "/cad-collaboration"
  },
  "monetization": {
    "allowedMethods": [
      "model_marketplace"
    ]
  }
}